{
  "id": "session-open-bad-matcher",
  "scenario": "session_start_hook_contract",
  "expect_only": true,
  "manifest": {
    "capabilities": [
      {
        "id": "session_open_awareness",
        "status": "lowered",
        "matcher": "startup|resume",
        "project_trust_required": true,
        "default_behavior": "on-demand",
        "runtime_artifacts": [
          ".codex/hooks.json",
          ".codex/hooks/relay-digest-session-start.mjs"
        ],
        "contract_consumers": [
          ".agents/skills/relay-digest/SKILL.md"
        ]
      }
    ],
    "generated_destinations": [
      ".agents/skills",
      ".codex/hooks",
      ".codex/hooks.json",
      "AGENTS.md"
    ]
  },
  "files": {
    ".agents/skills/relay-digest/SKILL.md": "> **Lifecycle awareness contract (Codex).** Default to invoking `relay-digest` on demand. A trusted `SessionStart` startup/resume hook may add a compact relay-aware note.\n",
    ".codex/hooks.json": "{\n  \"hooks\": {\n    \"SessionStart\": [\n      {\n        \"matcher\": \"startup\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"node .codex/hooks/relay-digest-session-start.mjs\",\n            \"timeout\": 5\n          }\n        ]\n      }\n    ]\n  }\n}\n",
    ".codex/hooks/relay-digest-session-start.mjs": "#!/usr/bin/env node\nprocess.exit(0);\n"
  },
  "expect_errors": [
    "session-open hooks matcher must be exactly \"startup|resume\""
  ]
}
